#!/bin/sh
# Headless ani-cli вЂ” no fzf, tput, rofi, or dmenu.
# Driven by the Tsukuyomi bot; auto-picks the first search result.

set -e

# в”Ђв”Ђ Config в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:150.0) Gecko/20100101 Firefox/150.0"
REFR="https://youtu-chan.com"
BASE="allanime.day"
API="https://api.${BASE}"
KEY="$(printf '%s' 'Xot36i3lK3:v1' | openssl dgst -sha256 -binary | od -A n -t x1 | tr -d ' \n')"
MODE="${ANI_CLI_MODE:-sub}"
DLDIR="${ANI_CLI_DOWNLOAD_DIR:-.}"
QUALITY="${ANI_CLI_QUALITY:-best}"

# в”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
log() { printf '%s\n' "$*" >&2; }

dep_check() {
    for d; do
        command -v "$d" >/dev/null 2>&1 || die "Required tool not found: $d"
    done
}

# в”Ђв”Ђ API / Scraping в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# Search and return lines of: ID|Title (N episodes)
search_anime() {
    query="$1"
    gql='query($search:SearchInput $limit:Int $page:Int $translationType:VaildTranslationTypeEnumType $countryOrigin:VaildCountryOriginEnumType){shows(search:$search limit:$limit page:$page translationType:$translationType countryOrigin:$countryOrigin){edges{_id name availableEpisodes __typename}}}'
    curl -s -A "$AGENT" -e "$REFR" \
        -H "Content-Type: application/json" \
        -X POST "${API}/api" \
        --data "{\"variables\":{\"search\":{\"allowAdult\":false,\"allowUnknown\":false,\"query\":\"${query}\"},\"limit\":40,\"page\":1,\"translationType\":\"${MODE}\",\"countryOrigin\":\"ALL\"},\"query\":\"${gql}\"}" \
    | sed 's/},{/\n/g' \
    | sed -nE "s@.*\"_id\":\"([^\"]+)\".*\"name\":\"([^\"]+)\".*\"${MODE}\":([1-9][0-9]*).*@\1|\2 (\3 episodes)@p" \
    | sed 's/\\\"//g'
}

# Get sorted episode list for a show ID
episodes_list() {
    show_id="$1"
    gql='query($showId:String!){show(_id:$showId){_id availableEpisodesDetail}}'
    curl -s -A "$AGENT" -e "$REFR" \
        -H "Content-Type: application/json" \
        -X POST "${API}/api" \
        --data "{\"variables\":{\"showId\":\"${show_id}\"},\"query\":\"${gql}\"}" \
    | sed -nE "s|.*\"${MODE}\":\[([^\]]*)\].*|\1|p" \
    | tr ',"' '\n' \
    | grep -E '^[0-9.]+$' \
    | sort -n
}

# Decode obfuscated source URL
decode_provider_id() {
    printf '%s' "$1" | sed 's/../&\n/g' \
    | sed 's/^79$/A/;s/^7a$/B/;s/^7b$/C/;s/^7c$/D/;s/^7d$/E/;s/^7e$/F/;s/^7f$/G/;s/^70$/H/;s/^71$/I/;s/^72$/J/;s/^73$/K/;s/^74$/L/;s/^75$/M/;s/^76$/N/;s/^77$/O/;s/^68$/P/;s/^69$/Q/;s/^6a$/R/;s/^6b$/S/;s/^6c$/T/;s/^6d$/U/;s/^6e$/V/;s/^6f$/W/;s/^60$/X/;s/^61$/Y/;s/^62$/Z/;s/^59$/a/;s/^5a$/b/;s/^5b$/c/;s/^5c$/d/;s/^5d$/e/;s/^5e$/f/;s/^5f$/g/;s/^50$/h/;s/^51$/i/;s/^52$/j/;s/^53$/k/;s/^54$/l/;s/^55$/m/;s/^56$/n/;s/^57$/o/;s/^48$/p/;s/^49$/q/;s/^4a$/r/;s/^4b$/s/;s/^4c$/t/;s/^4d$/u/;s/^4e$/v/;s/^4f$/w/;s/^40$/x/;s/^41$/y/;s/^42$/z/;s/^08$/0/;s/^09$/1/;s/^0a$/2/;s/^0b$/3/;s/^0c$/4/;s/^0d$/5/;s/^0e$/6/;s/^0f$/7/;s/^00$/8/;s/^01$/9/;s/^15$/-/;s/^16$/./;s/^67$/_/;s/^46$/~/;s/^02$/:/;s/^17$/\//;s/^07$/?/;s/^1b$/#/;s/^63$/[/;s/^65$/]/;s/^78$/@/;s/^19$/!/;s/^1c$/$/;s/^1e$/\&/;s/^10$/(/;s/^11$/)/;s/^12$/*/;s/^13$/+/;s/^14$/,/;s/^03$/;/;s/^05$/=/;s/^1d$/%/' \
    | tr -d '\n' \
    | sed 's|/clock|/clock.json|'
}

# Decrypt tobeparsed response
process_response() {
    if ! printf '%s' "$1" | grep -q '"tobeparsed"'; then
        printf '%s' "$1"
        return 0
    fi
    tmp="$(mktemp)"
    printf '%s' "$1" | sed -nE 's|.*"tobeparsed":"([^"]*)".*|\1|p' | base64 -d > "$tmp"
    fsize="$(wc -c < "$tmp")"
    iv="$(dd if="$tmp" bs=1 skip=1 count=12 2>/dev/null | od -A n -t x1 | tr -d ' \n')"
    ctr="${iv}00000002"
    ct_len=$((fsize - 13 - 16))
    dd if="$tmp" bs=1 skip=13 count="$ct_len" 2>/dev/null \
        | openssl enc -d -aes-256-ctr -K "$KEY" -iv "$ctr" -nosalt -nopad 2>/dev/null
    rm -f "$tmp"
}

# Get direct video links from a single provider URL
get_links() {
    url="$1"
    case "$url" in
        *mp4upload*)
            curl --max-time 10 -sLk -A "$AGENT" -e "$REFR" "$url" \
                | sed -nE 's|.*src: "([^"]*)".*|Mp4Upload >\1|p'
            ;;
        *tools.fast4speed*)
            printf 'Yt >%s\n' "$url"
            ;;
        *)
            resp="$(curl -s -A "$AGENT" -e "$REFR" "https://${BASE}${url}")"
            printf '%s' "$resp" \
                | sed 's/},{/\n/g' \
                | sed -nE 's|.*"link":"([^"]*)".*"resolutionStr":"([^"]*)".*|\2 >\1|p;
                            s|.*"hls","url":"([^"]*)".*"hardsub_lang":"en-US".*|\1|p'
            # handle m3u8 master playlists
            m3u8_url="$(printf '%s' "$resp" | sed -nE 's|.*"hls","url":"([^"]*)".*|\1|p' | head -1)"
            if [ -n "$m3u8_url" ] && printf '%s' "$m3u8_url" | grep -q 'master.m3u8'; then
                m3u8_refr="$(printf '%s' "$resp" | sed -nE 's|.*"Referer":"([^"]*)".*|\1|p')"
                rel="$(printf '%s' "$m3u8_url" | sed 's|[^/]*$||')"
                curl -s -A "$AGENT" -e "${m3u8_refr:-$REFR}" "$m3u8_url" \
                    | grep -v '^#EXT-X-I-FRAME' \
                    | sed 'N;s/\n/ >/' \
                    | sed -nE 's|.*x([0-9]+)[^>]*> *([^ ].*)|\1 >'"${rel}"'\2|p' \
                    | sort -rn
            fi
            ;;
    esac
}

# Fetch and score all links for current episode; set $EPISODE and $REFR_FLAG
get_episode_url() {
    ep_gql='query($showId:String!,$translationType:VaildTranslationTypeEnumType!,$episodeString:String!){episode(showId:$showId translationType:$translationType episodeString:$episodeString){episodeString sourceUrls}}'
    q_hash="d405d0edd690624b66baba3068e0edc3ac90f1597d898a1ec8db4e5c43c00fec"
    q_vars="{\"showId\":\"${SHOW_ID}\",\"translationType\":\"${MODE}\",\"episodeString\":\"${EP_NO}\"}"
    q_ext="{\"persistedQuery\":{\"version\":1,\"sha256Hash\":\"${q_hash}\"}}"

    # Try GET (persisted query) first, fall back to POST
    api_resp="$(curl -sG -A "$AGENT" -e "$REFR" -H "Origin: ${REFR}" "${API}/api" \
        --data-urlencode "variables=${q_vars}" \
        --data-urlencode "extensions=${q_ext}")"

    if [ -z "$api_resp" ] || ! printf '%s' "$api_resp" | grep -q 'tobeparsed'; then
        api_resp="$(curl -s -A "$AGENT" -e "$REFR" \
            -H "Content-Type: application/json" -X POST "${API}/api" \
            --data "{\"variables\":{\"showId\":\"${SHOW_ID}\",\"translationType\":\"${MODE}\",\"episodeString\":\"${EP_NO}\"},\"query\":\"${ep_gql}\"}")"
    fi

    # Parse source URLs
    sources="$(process_response "$api_resp" \
        | tr '{}' '\n' \
        | sed 's|\\u002F|/|g;s|\\||g' \
        | sed -nE 's|.*"sourceUrl":"([^"]*)".*"sourceName":"([^"]*)".*|\2:\1|p')"

    [ -z "$sources" ] && die "No sources found for episode ${EP_NO}"

    # Fetch links from all providers in parallel
    cache="$(mktemp -d)"
    i=0
    for src in $sources; do
        name="${src%%:*}"
        raw_url="${src#*:}"
        # decode obfuscated URLs (start with --)
        case "$raw_url" in
            --*) url="$(decode_provider_id "${raw_url#--}")" ;;
            *)   url="$raw_url" ;;
        esac
        [ -z "$url" ] && continue
        i=$((i+1))
        get_links "$url" > "${cache}/${i}" &
    done
    wait

    ALL_LINKS="$(cat "${cache}"/* 2>/dev/null | grep -v '^$' | sort -rn)"
    rm -rf "$cache"

    [ -z "$ALL_LINKS" ] && die "No video links found for episode ${EP_NO}"

    # Select quality
    case "$QUALITY" in
        best)  EPISODE="$(printf '%s' "$ALL_LINKS" | head -1 | cut -d'>' -f2)" ;;
        worst) EPISODE="$(printf '%s' "$ALL_LINKS" | grep -E '^[0-9]' | tail -1 | cut -d'>' -f2)" ;;
        *)     EPISODE="$(printf '%s' "$ALL_LINKS" | grep -m1 "$QUALITY" | cut -d'>' -f2)" ;;
    esac

    [ -z "$EPISODE" ] && {
        log "Quality ${QUALITY} not found, falling back to best"
        EPISODE="$(printf '%s' "$ALL_LINKS" | head -1 | cut -d'>' -f2)"
    }
    [ -z "$EPISODE" ] && die "Could not select episode URL"

    case "$(printf '%s' "$ALL_LINKS" | head -1)" in
        *mp4upload*) REFR_FLAG="https://www.mp4upload.com" ;;
        *sharepoint*) REFR_FLAG="" ;;
        *) REFR_FLAG="$REFR" ;;
    esac

    log "Selected URL: ${EPISODE}"
}

# в”Ђв”Ђ Download в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

do_download() {
    url="$1"
    outname="$2"
    outfile="${DLDIR}/${outname}.mp4"
    case "$url" in
        *m3u8*)
            if command -v yt-dlp >/dev/null 2>&1; then
                yt-dlp \
                    --referer "${M3U8_REFR:-$REFR}" \
                    --no-skip-unavailable-fragments \
                    --fragment-retries infinite \
                    -N 16 -o "$outfile" \
                    "$url"
            else
                ffmpeg -y \
                    -headers "Referer: ${M3U8_REFR:-$REFR}" \
                    -loglevel warning -stats \
                    -i "$url" -c copy "$outfile"
            fi
            ;;
        *)
            aria2c \
                --referer="${REFR_FLAG:-$REFR}" \
                --enable-rpc=false \
                --check-certificate=false \
                --continue=true \
                --summary-interval=0 \
                -x 16 -s 16 \
                --dir="$DLDIR" \
                -o "${outname}.mp4" \
                --download-result=hide \
                "$url"
            ;;
    esac
}

# в”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

QUERY=""
EP_NO=""
SELECT_NTH="1"

while [ $# -gt 0 ]; do
    case "$1" in
        -e|--episode|-r|--range)
            [ $# -lt 2 ] && die "missing argument for $1"
            EP_NO="$2"; shift ;;
        -q|--quality)
            [ $# -lt 2 ] && die "missing argument for $1"
            QUALITY="$2"; shift ;;
        -S|--select-nth)
            [ $# -lt 2 ] && die "missing argument for $1"
            SELECT_NTH="$2"; shift ;;
        --dub) MODE="dub" ;;
        -d|--download) ;; # always in download mode
        -V|--version) printf 'headless-ani-cli-1.0\n'; exit 0 ;;
        -h|--help)
            printf 'Usage: ani-cli -d -e <episode> [options] <anime name>\n'
            printf '  -e, --episode <n>    Episode number\n'
            printf '  -q, --quality <q>    Quality: best (default), worst, 1080p, 720p, ...\n'
            printf '  -S, --select-nth <n> Pick nth search result (default: 1)\n'
            printf '  --dub                Use dubbed version\n'
            exit 0 ;;
        # silently ignore GUI flags
        --rofi|--dmenu|--skip|--no-detach|--exit-after-play|-s|--syncplay|-v|--vlc|-c|--continue) ;;
        --skip-title|--skip-title) [ $# -gt 1 ] && shift ;;
        *) QUERY="${QUERY} $1" ;;
    esac
    shift
done

# Strip leading/trailing spaces from query
QUERY="$(printf '%s' "$QUERY" | sed 's/^ //;s/ $//')"

[ -z "$QUERY" ]  && die "No search query provided. Usage: ani-cli -d -e <episode> <anime name>"
[ -z "$EP_NO" ]  && die "No episode specified. Use -e <episode>."

dep_check curl sed grep openssl ffmpeg aria2c

# в”Ђв”Ђ Search в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

log "Searching: ${QUERY}"
# search_anime outputs lines of format: ID|Title (N episodes)
RESULTS="$(search_anime "$QUERY")"
[ -z "$RESULTS" ] && die "No results found for: ${QUERY}"

log "Results:"
printf '%s\n' "$RESULTS" | head -5 | while IFS='|' read -r rid rname; do
    log "  ${rid} -> ${rname}"
done >&2

# Pick the Nth result
SHOW_LINE="$(printf '%s\n' "$RESULTS" | sed -n "${SELECT_NTH}p")"
[ -z "$SHOW_LINE" ] && SHOW_LINE="$(printf '%s\n' "$RESULTS" | head -1)"
[ -z "$SHOW_LINE" ] && die "Could not select a result."

SHOW_ID="$(printf '%s' "$SHOW_LINE" | cut -d'|' -f1)"
SHOW_TITLE="$(printf '%s' "$SHOW_LINE" | cut -d'|' -f2)"

[ -z "$SHOW_ID" ] && die "Failed to extract show ID from: ${SHOW_LINE}"

log "Selected [${SELECT_NTH}]: ${SHOW_TITLE} (ID: ${SHOW_ID})"

# в”Ђв”Ђ Episode list в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

EP_LIST="$(episodes_list "$SHOW_ID")"
[ -z "$EP_LIST" ] && die "No episodes found for show ID: ${SHOW_ID}"

log "Available episodes: $(printf '%s' "$EP_LIST" | tr '\n' ' ')"

# Validate that the requested episode exists
if ! printf '%s\n' "$EP_LIST" | grep -qx "$EP_NO"; then
    log "Warning: episode ${EP_NO} not in episode list вЂ” attempting anyway"
fi

# в”Ђв”Ђ Fetch & download в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

log "Fetching episode ${EP_NO} of ${SHOW_TITLE}..."
get_episode_url

SAFE_TITLE="$(printf '%s' "$SHOW_TITLE" | sed 's/[^a-zA-Z0-9._-]/_/g')"
OUTNAME="${SAFE_TITLE}_E$(printf '%02d' "$EP_NO")"

log "Downloading to ${DLDIR}/${OUTNAME}.mp4 ..."
do_download "$EPISODE" "$OUTNAME"
log "Done: ${DLDIR}/${OUTNAME}.mp4"
