# ─── Telegram Bot Credentials ───────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Your bot token from @BotFather
BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNooP

# Your Telegram user ID (owner / super admin)
OWNER_ID=123456789

# Authorized uploaders (space-separated user IDs, in addition to OWNER_ID)
AUTH_USERS=111111111 222222222

# ─── Channels ────────────────────────────────────────────────────────────────
# DUMP_CHANNEL: private channel where watermarked videos are stored permanently
# Bot must be admin with post permissions
DUMP_CHANNEL=-1001234567890

# FLOG_CHANNEL: file log channel (used for multi-client file_id caching)
FLOG_CHANNEL=-1001234567891

# ULOG_CHANNEL: user/activity log channel
ULOG_CHANNEL=-1001234567892

# ─── Web Server ───────────────────────────────────────────────────────────────
PORT=5000
BIND_ADDRESS=0.0.0.0

# Public domain (e.g. your Replit app URL without trailing slash)
# FQDN=your-repl-name.repl.co
# NO_PORT=true
# HAS_SSL=true

# ─── Site API Auth ───────────────────────────────────────────────────────────
# Random secret key — your website sends this as X-API-Key header
SITE_API_KEY=change-me-to-a-long-random-string

# Secret used to sign stream tokens — keep private, minimum 32 chars
STREAM_SECRET=change-me-to-another-long-random-secret

# ─── Database Paths ───────────────────────────────────────────────────────────
BOT_DB_PATH=data/bot.db
SITE_DB_PATH=data/site.db

# ─── Optional ─────────────────────────────────────────────────────────────────
WORKERS=6
SLEEP_THRESHOLD=60

# Multi-client bot tokens for load balancing (optional)
# MULTI_TOKEN1=bot-token-2
# MULTI_TOKEN2=bot-token-3
